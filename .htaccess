# ============================================================
# .htaccess für /scan/QR_WebApp/
# Erreichbar unter: https://scan.s-r-portrait.de/QR_WebApp/
# ============================================================

Options -Indexes

# --- Sensible Dateien vor direktem HTTP-Zugriff sperren ---
<FilesMatch "\.(json|md|log|sql|sh|env|gitignore)$">
    Require all denied
</FilesMatch>

# Debug-Hilfsdateien sperren (nur lokal nützlich)
<FilesMatch "^(debug_config|debug_login|gen_hash)\.php$">
    Require all denied
</FilesMatch>

# --- Zeichensatz ---
AddDefaultCharset UTF-8

# --- Sicherheits-Header ---
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
